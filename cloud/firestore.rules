// Paste this into your Firebase project:
//   Firestore Database -> Rules tab -> overwrite -> Publish
//
// Model:
//   - /config/access is a single document holding the team:
//       editors: [<email>, ...]   can read + write tasks
//       viewers: [<email>, ...]   can read only
//   - /tasks/{id} is one task per document.
//
// Bootstrap (one time, in the Firestore console):
//   - Manually create a document at path: config/access
//   - Add field `editors` (array of strings) with at least YOUR email
//   - Optionally add `viewers` (array of strings)
//   - Without this doc, nobody can read anything (intentional).

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null && request.auth.token.email != null; }
    function userEmail() { return request.auth.token.email.lower(); }
    function accessDoc() { return get(/databases/$(database)/documents/config/access).data; }
    function emailIn(field) {
      return accessDoc()[field] is list && userEmail() in accessDoc()[field];
    }
    function isAdmin() { return isSignedIn() && emailIn('admins'); }
    function isEditor() { return isSignedIn() && (emailIn('admins') || emailIn('editors')); }
    function isViewer() { return isSignedIn() && (emailIn('admins') || emailIn('editors') || emailIn('viewers')); }

    match /config/access {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isViewer();
      allow create: if isEditor();
      allow delete: if isAdmin() || (
        isEditor() && (
          ('assignees' in resource.data && userEmail() in resource.data.assignees) ||
          ('createdBy' in resource.data && userEmail() == resource.data.createdBy.lower())
        )
      );
      allow update: if isAdmin() || (
        isEditor() && (
          ('assignees' in resource.data && userEmail() in resource.data.assignees) ||
          ('createdBy' in resource.data && userEmail() == resource.data.createdBy.lower())
        )
      ) || (
        isViewer() &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['updates'])
      );
    }

    match /profiles/{email} {
      allow read: if isViewer();
      allow write: if isEditor() || (isSignedIn() && userEmail().lower() == email.lower());
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (userEmail() == resource.data.toEmail.lower() || isAdmin());
      allow create: if isEditor();
      allow update: if isSignedIn() && (userEmail() == resource.data.toEmail.lower() || isAdmin()) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && (userEmail() == resource.data.toEmail.lower() || isAdmin());
    }
  }
}
